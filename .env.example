# Copy these values into your IDE run configuration or environment.
# The backend reads real OS environment variables via System.getenv(...).

SERPAPI_API_KEY=replaceme
SERPAPI_ENGINE=google_jobs
SERPAPI_BASE_URL=https://serpapi.com/search.json

MONGODB_URI=replaceme
MONGODB_DB_NAME=joblens
MONGODB_COLLECTION_PREFS=user_preferences
MONGODB_COLLECTION_HISTORY=recommendation_history
MONGODB_COLLECTION_LOGS=request_logs

SCHEDULE_DAY_OF_WEEK=MONDAY
SCHEDULE_HOUR_UTC=9
SCHEDULE_MINUTE_UTC=0

MAX_RESULTS_RETURNED=50
NATIONWIDE_US_MAX_STATES=12
NATIONWIDE_US_MIN_STATES=4
