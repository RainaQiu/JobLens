<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_job_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_job_company"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_job_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_soft"
                android:textColor="@color/brand_ink"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_job_posted_at"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill_soft"
                android:textColor="@color/brand_ink"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_job_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/text_job_apply_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/brand_teal_dark"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_job_apply"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/apply_now"
            app:backgroundTint="@color/brand_teal"
            app:cornerRadius="18dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
